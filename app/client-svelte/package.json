    "prettierApply": "npx prettier --write src",
    "prettierCheck": "npx prettier --check src"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tailwindcss/postcss": "4.2.2",
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.5",
    "chance": "1.1.13",
    "daisyui": "5.5.19",
    "dotenv": "17.4.2",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.1",
    "rxjs": "7.8.2",
    "svelte": "5.55.4",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "uuid": "14.0.0",
    "vite": "8.0.9",
    "vitest": "4.1.5"
  },
  "type": "module"
}
