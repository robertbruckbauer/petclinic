{
  "name": "client-svelte",
  "version": "1.6.0",
  "scripts": {
    "build": "vite build",
    "start": "vite serve --port 5050",
    "test": "vitest run --coverage",
    "e2e": "npx playwright test",
    "e2e-headed": "npx playwright test --headed",
    "e2e-codegen": "npx playwright codegen localhost:5050",
