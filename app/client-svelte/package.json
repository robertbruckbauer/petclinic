    "prettierCheck": "npx prettier --check src"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tailwindcss/postcss": "4.3.3",
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "chance": "1.1.13",
    "daisyui": "5.6.18",
    "dotenv": "17.4.2",
    "prettier": "3.9.5",
    "prettier-plugin-svelte": "4.1.1",
    "rxjs": "7.8.2",
    "svelte": "5.56.5",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "uuid": "14.0.1",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "type": "module"
}
