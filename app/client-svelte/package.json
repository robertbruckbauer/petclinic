{
  "name": "client-svelte",
  "version": "1.7.0",
  "scripts": {
    "build": "vite build",
    "start": "vite serve --port 5050",
    "test": "vitest run --coverage",
    "e2e": "pnpm exec playwright test",
    "e2e-headed": "pnpm exec playwright test --headed",
    "e2e-codegen": "pnpm exec playwright codegen localhost:5050",
    "e2e-install": "pnpm exec playwright install",
    "prettierApply": "pnpm exec prettier --write src",
    "prettierCheck": "pnpm exec prettier --check src"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/postcss": "4.3.0",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.6",
    "chance": "1.1.13",
    "daisyui": "5.5.19",
    "dotenv": "17.4.2",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.2",
    "rxjs": "7.8.2",
    "svelte": "5.55.7",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "uuid": "14.0.0",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  },
  "type": "module"
}
