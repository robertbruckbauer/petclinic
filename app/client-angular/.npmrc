save-exact=true
# sass requires chokidar@^4.0.0 as a regular dependency, while @angular-devkit/core
# declares chokidar@^5.0.0 as an optional peer dependency. These version ranges are
# incompatible, so npm 7+ peer dep resolution would hoist chokidar@5 to the top level
# and remove chokidar@4 (and its transitive dependency readdirp) from the lock file.
# legacy-peer-deps reverts to npm v6 peer dep behaviour, ignoring optional peer deps
# and keeping chokidar@4 at the top level.
legacy-peer-deps=true
